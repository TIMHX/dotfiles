function t() {
  # 1. 获取输入并选择
  local session=$(sesh list -z | fzf --height 40% --reverse --header "Connect to Session")
  # 2. 如果用户没取消选择
  if [[ -n "$session" ]]; then
    # 【核心修复】: 
    # 使用 sed 移除所有非打印字符/特殊图标
    # 并使用 xargs 处理可能存在的波浪号 (~) 路径展开问题
    local clean_session=$(echo "$session" | sed 's/[^[:print:]]//g' | awk '{print $NF}')
    
    # 3. 连接
    sesh connect "$clean_session"
  fi
}

czp() {
    # 1. 同步本地修改到 chezmoi 备份目录
    echo "🔄 Syncing local changes to source..."
    chezmoi re-add

    local SOURCE_DIR=$(chezmoi source-path)

    # 2. 检查是否有变动
    if [ -n "$(git -C "$SOURCE_DIR" status --porcelain)" ]; then
        echo "🧐 Current changes in source directory:"
        # 打印简短的状态，让你一眼看出哪些文件变了
        git -C "$SOURCE_DIR" status --short

        # 🛑 核心改进：交互式询问
        echo -n "⚠️  Do you want to commit and push these changes? (y/n) "
        read -r answer
        
        if [[ "$answer" =~ ^[Yy]$ ]]; then
            echo "📝 Committing changes..."
            git -C "$SOURCE_DIR" add .
            git -C "$SOURCE_DIR" commit -m "Auto-update: $(date +'%Y-%m-%d %H:%M:%S')"
            
            echo "📤 Pushing to remote..."
            git -C "$SOURCE_DIR" push
            echo "✅ Done!"
        else
            echo "✖️  Push cancelled. Changes are kept in the source directory but not pushed."
        fi
    else
        echo "✨ Everything is up to date."
    fi
}

cza() {
    if [ -z "$1" ]; then
      echo "Usage: cza <file_path>"
        return 1
    fi
    chezmoi add "$1"
    echo "➕ Added $1 to chezmoi."
    czp # 自动调用上面的上传函数
}


